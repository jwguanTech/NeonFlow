<!-- 
	该页面为主页面
	1、难度调节
	2、跳转至游戏页面并传参
-->
<template>
	<view class="container">
		<view class="game-title">
			<text class="title-text">Neon Flow</text>
		</view>
		
		<view class="game-options">
			<view class="option-item">
				<text class="option-label">难度选择：</text>
				<picker mode="selector" :value="difficultyIndex" :range="difficultyOptions" @change="onDifficultyChange">
					<view class="picker">{{difficultyOptions[difficultyIndex]}}</view>
				</picker>
			</view>
		</view>
		
		<view class="start-btn-container">
			<button class="start-btn" @tap="startGame">开始游戏</button>
		</view>
	</view>
</template>

<script lang="uts">
	export default {
		data() {
			return {
				difficultyIndex: 1,
				difficultyOptions: ['简单', '普通', '困难']
			}
		},
		onLoad() {
			
		},
		methods: {
			onDifficultyChange(e : any) {
				this.difficultyIndex = parseInt(e.detail.value)
			},
			startGame() {
				const difficulty = this.difficultyOptions[this.difficultyIndex]
				const url = '/pages/game/game?difficulty=' + encodeURIComponent(difficulty)
				console.log('Navigate to:', url)
				uni.navigateTo({
					url: url
				})
			}
		}
	}
</script>

