	}
	
	.game-title {
		margin-top: 60px;
		margin-bottom: 80px;
	}
	
	.title-text {
		font-size: 48px;
		font-weight: bold;
		color: #00d4ff;
	}
	
	.game-options {
		width: 100%;
		max-width: 350px;
		margin-bottom: 60px;
	}
	
	.option-item {
		display: flex;
		flex-direction: row;
		align-items: center;
		margin-bottom: 30px;
		background: rgba(255, 255, 255, 0.1);
		padding: 15px 20px;
		border-radius: 12px;
	}
	
	.option-label {
		color: #ffffff;
		font-size: 16px;
